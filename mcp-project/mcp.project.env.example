## Per-project MCP secrets/config (copy to mcp.project.env)
## NOTE: Cursor reads ~/.cursor/mcp.json, not this file directly.
## This is for you to keep per-project values in one place.

# LINEAR_API_KEY=
# JIRA_BASE_URL=https://your-workspace.atlassian.net
# JIRA_PERSONAL_ACCESS_TOKEN=email@example.com:your_pat
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# DATABASE_URI=postgresql://USER:PASSWORD@HOST:5432/DBNAME

